<component prop:text="Station" prop:visible="true" prop:rotation="0" prop:textRotation="0" prop:align="center,center" prop:children>
  <variant prop:textLocation="top">
    <frame align="center,bottom" width="hug" height="hug" flow="vertical" clip="false" locked="true">
      <import from="station-text.figml" text="$$prop:text$$" visible="$$prop:visible$$" align="right,bottom" rotation="$$prop:textRotation$$" />
      <import from="station-content.figml" visible="$$prop:visible$$" rotation="$$prop:rotation$$" align="$$prop:align$$">
        $$prop:children$$
      </import>
    </frame>
  </variant>
  <variant prop:textLocation="bottom">
    <frame align="center,top" width="hug" height="hug" flow="vertical" clip="false" locked="true">
      <import from="station-content.figml" visible="$$prop:visible$$" rotation="$$prop:rotation$$" align="$$prop:align$$">
        $$prop:children$$
      </import>
      <import from="station-text.figml" text="$$prop:text$$" visible="$$prop:visible$$" align="left,top" rotation="$$prop:textRotation$$" />
    </frame>
  </variant>
  <variant prop:textLocation="left">
    <frame align="right,center" width="hug" height="hug" flow="horizontal" clip="false" locked="true" stacking="first">
      <import from="station-text.figml" text="$$prop:text$$" visible="$$prop:visible$$" align="right,center" rotation="$$prop:textRotation$$" />
      <import from="station-content.figml" visible="$$prop:visible$$" rotation="$$prop:rotation$$" align="$$prop:align$$">
        $$prop:children$$
      </import>
    </frame>
  </variant>
  <variant prop:textLocation="right">
    <frame align="left,center" width="hug" height="hug" flow="horizontal" clip="false" locked="true">
      <import from="station-content.figml" visible="$$prop:visible$$" rotation="$$prop:rotation$$" align="$$prop:align$$">
        $$prop:children$$
      </import>
      <import from="station-text.figml" text="$$prop:text$$" visible="$$prop:visible$$" align="left,center" rotation="$$prop:textRotation$$" />
    </frame>
  </variant>
</component>
